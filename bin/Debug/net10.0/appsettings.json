{
  "ApiSettings": {
    "Nome": "GVC Mobile API",
    "Versao": "1.0.0"
  },

  "ImageSettings": {
    "ImageFolder": "",
    "DefaultImage": "sem-imagem.png"
  },

  "SyncSettings": {
    "HorasRetencaoArquivos": 6,
    "IntervaloLimpezaMinutos": 30
  },

  "ApiKeySettings": {
    "Enabled": true,
    "HeaderName": "X-GVC-API-Key",
    "Key": ""
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ]
  },

  "AllowedHosts": "*"
}