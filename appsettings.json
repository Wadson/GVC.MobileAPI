{


  "ConnectionStrings": {
    "DefaultConnection": "Data Source=WR-PC\\SQLEXPRESS;Initial Catalog=bdgvc;User ID=gvc_userteste;Password=gvcuser@;TrustServerCertificate=True;"
  },




  "ApiSettings": {
    "Nome": "GVC Mobile API",
    "Versao": "1.0.0"
  },

  "ImageSettings": {
    "ImageFolder": "D:\\PROGRAM FILES\\MONEY\\Imagem",
    "DefaultImage": "SemImagem.png"
  },

  "SyncSettings": {
    "HorasRetencaoArquivos": 6,
    "IntervaloLimpezaMinutos": 30
  },

  "ApiKeySettings": {
    "Enabled": true,
    "HeaderName": "X-GVC-API-Key",
    "Key": "123456"
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },

  "AllowedHosts": "*"
}